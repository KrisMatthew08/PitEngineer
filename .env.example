# Copy this file to .env and fill in your key, OR run `ant auth login` and leave it unset.
# The app resolves credentials the same way the Anthropic SDK does:
#   ANTHROPIC_API_KEY -> ANTHROPIC_AUTH_TOKEN -> `ant auth login` profile.
ANTHROPIC_API_KEY=

# Optional: point at your Assetto Corsa setups folder.
# Default (Windows): %USERPROFILE%\Documents\Assetto Corsa\setups
AC_SETUPS_DIR=
